@prefix lv2: <http://lv2plug.in/ns/lv2core#> .
@prefix doap: <http://usefulinc.com/ns/doap#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix units: <http://lv2plug.in/ns/extensions/units#> .
@prefix ui: <http://lv2plug.in/ns/extensions/ui#> .

<https://github.com/Rui-727/OTT>
    a lv2:Plugin , lv2:CompressorPlugin ;
    doap:name "OTT" ;
    doap:license <http://opensource.org/licenses/MIT> ;
    doap:maintainer [
        a foaf:Person ;
        foaf:name "Rui-727" ;
        rdfs:seeAlso <https://github.com/Rui-727>
    ] ;
    lv2:project <https://github.com/Rui-727/OTT> ;
    lv2:optionalFeature lv2:hardRTCapable ;
    ui:ui <https://github.com/Rui-727/OTT#ui> ;
    lv2:port [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 0 ;
        lv2:symbol "depth" ;
        lv2:name "Depth" ;
        lv2:default 1.0 ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
        units:unit units:coef ;
    ] , [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 1 ;
        lv2:symbol "time" ;
        lv2:name "Time" ;
        lv2:default 0.5 ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
        units:unit units:coef ;
    ] , [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 2 ;
        lv2:symbol "upward" ;
        lv2:name "Upward" ;
        lv2:default 1.0 ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
        units:unit units:coef ;
    ] , [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 3 ;
        lv2:symbol "downward" ;
        lv2:name "Downward" ;
        lv2:default 1.0 ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
        units:unit units:coef ;
    ] , [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 4 ;
        lv2:symbol "input_gain" ;
        lv2:name "Input Gain" ;
        lv2:default 5.2 ;
        lv2:minimum -24.0 ;
        lv2:maximum 24.0 ;
        units:unit units:db ;
    ] , [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 5 ;
        lv2:symbol "output_gain" ;
        lv2:name "Output Gain" ;
        lv2:default 0.0 ;
        lv2:minimum -24.0 ;
        lv2:maximum 24.0 ;
        units:unit units:db ;
    ] , [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 6 ;
        lv2:symbol "band1_thresh" ;
        lv2:name "Band 1 Threshold" ;
        lv2:default -30.0 ;
        lv2:minimum -60.0 ;
        lv2:maximum 0.0 ;
        units:unit units:db ;
    ] , [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 7 ;
        lv2:symbol "band2_thresh" ;
        lv2:name "Band 2 Threshold" ;
        lv2:default -30.0 ;
        lv2:minimum -60.0 ;
        lv2:maximum 0.0 ;
        units:unit units:db ;
    ] , [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 8 ;
        lv2:symbol "band3_thresh" ;
        lv2:name "Band 3 Threshold" ;
        lv2:default -30.0 ;
        lv2:minimum -60.0 ;
        lv2:maximum 0.0 ;
        units:unit units:db ;
    ] , [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 9 ;
        lv2:symbol "band1_gain" ;
        lv2:name "Band 1 Gain" ;
        lv2:default 10.3 ;
        lv2:minimum -24.0 ;
        lv2:maximum 24.0 ;
        units:unit units:db ;
    ] , [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 10 ;
        lv2:symbol "band2_gain" ;
        lv2:name "Band 2 Gain" ;
        lv2:default 5.7 ;
        lv2:minimum -24.0 ;
        lv2:maximum 24.0 ;
        units:unit units:db ;
    ] , [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 11 ;
        lv2:symbol "band3_gain" ;
        lv2:name "Band 3 Gain" ;
        lv2:default 10.3 ;
        lv2:minimum -24.0 ;
        lv2:maximum 24.0 ;
        units:unit units:db ;
    ] , [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 12 ;
        lv2:symbol "bypass" ;
        lv2:name "Bypass" ;
        lv2:default 0.0 ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
        lv2:portProperty lv2:toggled , lv2:integer ;
    ] , [
        a lv2:InputPort , lv2:AudioPort ;
        lv2:index 13 ;
        lv2:symbol "in_l" ;
        lv2:name "In L" ;
    ] , [
        a lv2:InputPort , lv2:AudioPort ;
        lv2:index 14 ;
        lv2:symbol "in_r" ;
        lv2:name "In R" ;
    ] , [
        a lv2:OutputPort , lv2:AudioPort ;
        lv2:index 15 ;
        lv2:symbol "out_l" ;
        lv2:name "Out L" ;
    ] , [
        a lv2:OutputPort , lv2:AudioPort ;
        lv2:index 16 ;
        lv2:symbol "out_r" ;
        lv2:name "Out R" ;
    ] .

<https://github.com/Rui-727/OTT#ui>
    a ui:X11UI ;
    lv2:optionalFeature ui:idleInterface ,
                        ui:touch ;
    lv2:extensionData ui:idleInterface ,
                      ui:showInterface ;
    ui:fixedSize true .
